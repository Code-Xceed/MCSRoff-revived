{
  "name": "mcsroff-auth-site",
  "version": "1.0.0",
  "private": true,
  "description": "Local auth website and device-link backend for the MCSR Offline mod.",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "start:legacy": "node server.js",
    "check": "node --check src/server.js && node --check server.js",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test-auth": "node test-auth-flow.js",
    "test-admin": "node test-admin-flow.js",
    "test-matchmaking": "node test-matchmaking-flow.js",
    "export-runtime-sql": "node scripts/exportRuntimeSql.js",
    "validate-postgres-runtime": "node scripts/validatePostgresRuntime.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.0",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "msgpackr": "^1.11.9",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.3"
  }
}
