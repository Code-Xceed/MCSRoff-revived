# ── Server ──
PORT=8080
HOST=127.0.0.1
BASE_URL=http://localhost:8080
NODE_ENV=development

# ── Storage Backend ──
# Options: 'json' (file-based, dev only) or 'postgres' (production)
STORAGE_BACKEND=json

# ── PostgreSQL (required when STORAGE_BACKEND=postgres) ──
# Direct connection string — bypasses PostgREST for 5-10x performance
DATABASE_URL=postgresql://user:password@localhost:5432/mcsroff

# Legacy Supabase REST (only if using postgresRepositories via PostgREST)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Redis (optional — in-memory fallback used if not set) ──
REDIS_URL=redis://localhost:6379

# ── PostgreSQL Pool Tuning ──
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000
PG_STATEMENT_TIMEOUT_MS=10000
PG_SSL=false

# ── Auth ──
# JWT_PRIVATE_KEY_PATH=./keys/private.pem
# JWT_PUBLIC_KEY_PATH=./keys/public.pem

# ── FSG Seed API ──
FSG_API_BASE_URL=https://www.filteredseed.com
# FSG_STATIC_SEED=123456789
# FSG_STATIC_FILTER=zsg
# FSG_STATIC_TOKEN=test-token

# ── Rate Limits ──
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=40
MATCH_RATE_LIMIT_WINDOW_MS=60000
MATCH_RATE_LIMIT_MAX=600
PAGE_RATE_LIMIT_WINDOW_MS=60000
PAGE_RATE_LIMIT_MAX=120

# ── Match Presence Timeouts ──
MATCH_PLAYER_STALE_MILLIS=15000
MATCH_PRESTART_STALE_MILLIS=180000
MATCH_WORLD_LOADING_STALE_MILLIS=900000
MATCH_RUNNING_STALE_MILLIS=180000

# ── CORS ──
CORS_ORIGINS=*

# ── Admin ──
ADMIN_USERNAMES=

# ── Logging ──
LOG_LEVEL=info
